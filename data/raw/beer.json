.png/36px-Silver_Quality_Icon.png 1.5x, /mediawiki/images/8/8a/Silver_Quality_Icon.png 2x\" /></div></div></td>\n\t<td>350g\n\t</td>\n</tr><tr>\n\t<td><link rel=\"mw-deduplicated-inline-style\" href=\"mw-data:TemplateStyles:r146727\"/><div class=\"parent\" style=\"width: 24px; height: auto; margin: 0 auto;\"><div class=\"backimage\"><img alt=\"Beer.png\" src=\"/mediawiki/images/thumb/b/b3/Beer.png/24px-Beer.png\" decoding=\"async\" width=\"24\" height=\"24\" srcset=\"/mediawiki/images/thumb/b/b3/Beer.png/36px-Beer.png 1.5x, /mediawiki/images/b/b3/Beer.png 2x\" /></div><div class=\"foreimage\"><img alt=\"Gold Quality Icon.png\" src=\"/mediawiki/images/thumb/4/47/Gold_Quality_Icon.png/24px-Gold_Quality_Icon.png\" decoding=\"async\" width=\"24\" height=\"24\" srcset=\"/mediawiki/images/thumb/4/47/Gold_Quality_Icon.png/36px-Gold_Quality_Icon.png 1.5x, /mediawiki/images/4/47/Gold_Quality_Icon.png 2x\" /></div></div></td>\n\t<td>420g\n\t</td>\n</tr><tr>\n\t<td><link rel=\"mw-deduplicated-inline-style\" href=\"mw-data:TemplateStyles:r146727\"/><div class=\"parent\" style=\"width: 24px; height: auto; margin: 0 auto;\"><div class=\"backimage\"><img alt=\"Beer.png\" src=\"/mediawiki/images/thumb/b/b3/Beer.png/24px-Beer.png\" decoding=\"async\" width=\"24\" height=\"24\" srcset=\"/mediawiki/images/thumb/b/b3/Beer.png/36px-Beer.png 1.5x, /mediawiki/images/b/b3/Beer.png 2x\" /></div><div class=\"foreimage\"><img alt=\"Iridium Quality Icon.png\" src=\"/mediawiki/images/thumb/e/e4/Iridium_Quality_Icon.png/24px-Iridium_Quality_Icon.png\" decoding=\"async\" width=\"24\" height=\"24\" srcset=\"/mediawiki/images/thumb/e/e4/Iridium_Quality_Icon.png/36px-Iridium_Quality_Icon.png 1.5x, /mediawiki/images/e/e4/Iridium_Quality_Icon.png 2x\" /></div></div></td>\n\t<td>560g\n\t</td>\n</tr></tbody></table></td>\n\t\t\t</tr>\n\t\t\t</tbody></table>\n\t\t</td>\n</tr>\n\t<tr>\n\t\t<td colspan=\"2\" id=\"infoboxsection\" style=\"text-align: center; padding-left: 0; padding-right: 0;\">Artisan Goods</td>\n\t</tr>\n\t<tr>\n\t\t<td id=\"infoboxsection\">Equipment</td>\n\t\t<td id=\"infoboxdetail\"><link rel=\"mw-deduplicated-inline-style\" href=\"mw-data:TemplateStyles:r120955\"/><span class=\"nametemplate\"><img alt=\"Keg.png\" src=\"/mediawiki/images/thumb/7/7c/Keg.png/24px-Keg.png\" decoding=\"async\" width=\"24\" height=\"48\" srcset=\"/mediawiki/images/thumb/7/7c/Keg.png/36px-Keg.png 1.5x, /mediawiki/images/7/7c/Keg.png 2x\" /> <a href=\"/Keg\" title=\"Keg\">Keg</a></span></td>\n\t</tr>\n\t<tr>\n\t\t<td id=\"infoboxsection\">Processing Time</td>\n\t\t<td id=\"infoboxdetail\"><link rel=\"mw-deduplicated-inline-style\" href=\"mw-data:TemplateStyles:r120974\"/><span class=\"durationtemplate\"><img alt=\"Time Icon.png\" src=\"/mediawiki/images/thumb/7/70/Time_Icon.png/24px-Time_Icon.png\" decoding=\"async\" width=\"24\" height=\"24\" srcset=\"/mediawiki/images/thumb/7/70/Time_Icon.png/36px-Time_Icon.png 1.5x, /mediawiki/images/7/70/Time_Icon.png 2x\" /> 1750m (&#8776;29h)</span></td>\n\t</tr>\n\t<tr>\n\t\t<td id=\"infoboxsection\">Ingredients</td>\n\t\t<td id=\"infoboxdetail\"><link rel=\"mw-deduplicated-inline-style\" href=\"mw-data:TemplateStyles:r120955\"/><span class=\"nametemplate\"><img alt=\"Wheat.png\" src=\"/mediawiki/images/thumb/e/e2/Wheat.png/24px-Wheat.png\" decoding=\"async\" width=\"24\" height=\"24\" srcset=\"/mediawiki/images/thumb/e/e2/Wheat.png/36px-Wheat.png 1.5x, /mediawiki/images/e/e2/Wheat.png 2x\" /> <a href=\"/Wheat\" title=\"Wheat\">Wheat</a>&#160;(1)</span></td>\n\t</tr>\n</tbody></table>\n</div>\n<p><b>Beer</b> is an <a href=\"/Artisan_Goods\" title=\"Artisan Goods\">Artisan Good</a> made from the <a href=\"/Keg\" title=\"Keg\">Keg</a> using <a href=\"/Wheat\" title=\"Wheat\">Wheat</a>, taking 1-2 days. It is also available at <a href=\"/The_Stardrop_Saloon\" title=\"The Stardrop Saloon\">The Saloon</a> for <span style=\"display: none;\">data-sort-value=\"400\"&gt;</span><span class=\"no-wrap\"><img alt=\"Gold.png\" src=\"/mediawiki/images/thumb/1/10/Gold.png/18px-Gold.png\" decoding=\"async\" width=\"18\" height=\"18\" srcset=\"/mediawiki/images/thumb/1/10/Gold.png/27px-Gold.png 1.5x, /mediawiki/images/thumb/1/10/Gold.png/36px-Gold.png 2x\" />400g</span> and the <a href=\"/Ginger_Island#Island_South\" title=\"Ginger Island\">Ginger Island Resort</a> for <span style=\"display: none;\">data-sort-value=\"500\"&gt;</span><span class=\"no-wrap\"><img alt=\"Gold.png\" src=\"/mediawiki/images/thumb/1/10/Gold.png/18px-Gold.png\" decoding=\"async\" width=\"18\" height=\"18\" srcset=\"/mediawiki/images/thumb/1/10/Gold.png/27px-Gold.png 1.5x, /mediawiki/images/thumb/1/10/Gold.png/36px-Gold.png 2x\" />500g</span>.  It can also be received as a gift at the <a href=\"/Feast_of_the_Winter_Star\" title=\"Feast of the Winter Star\">Feast of the Winter Star</a>. <a href=\"/Pam\" title=\"Pam\">Pam</a> sells Beer in her <a href=\"/Desert_Festival#Villager_Shops\" title=\"Desert Festival\">shop</a> at the <a href=\"/Desert_Festival\" title=\"Desert Festival\">Desert Festival</a> for <span style=\"display: none;\">data-sort-value=\"20\"&gt;</span><span class=\"no-wrap\"><img alt=\"Calico Egg.png\" src=\"/mediawiki/images/thumb/d/da/Calico_Egg.png/24px-Calico_Egg.png\" decoding=\"async\" width=\"24\" height=\"24\" srcset=\"/mediawiki/images/thumb/d/da/Calico_Egg.png/36px-Calico_Egg.png 1.5x, /mediawiki/images/d/da/Calico_Egg.png 2x\" /> 20</span> <a href=\"/Calico_Egg\" title=\"Calico Egg\">Calico Eggs</a>.\n</p><p>When consumed, Beer causes a <a href=\"/Buffs\" title=\"Buffs\">Tipsy Buff</a> that decreases <a href=\"/Speed\" title=\"Speed\">Speed</a> by 1.\n</p>\n<div id=\"toc\" class=\"toc\" role=\"navigation\" aria-labelledby=\"mw-toc-heading\"><input type=\"checkbox\" role=\"button\" id=\"toctogglecheckbox\" class=\"toctogglecheckbox\" style=\"display:none\" /><div class=\"toctitle\" lang=\"en\" dir=\"ltr\"><h2 id=\"mw-toc-heading\">Contents</h2><span class=\"toctogglespan\"><label class=\"toctogglelabel\" for=\"toctogglecheckbox\"></label></span></div>\n<ul>\n<li class=\"toclevel-1 tocsection-1\"><a href=\"#Aged_Values\"><span class=\"tocnumber\">1</span> <span class=\"toctext\">Aged Values</span></a></li>\n<li class=\"toclevel-1 tocsection-2\"><a href=\"#Gifting\"><span class=\"tocnumber\">2</span> <span class=\"toctext\">Gifting</span></a></li>\n<li class=\"toclevel-1 tocsection-3\"><a href=\"#Bundles\"><span class=\"tocnumber\">3</span> <span class=\"toctext\">Bundles</span></a></li>\n<li class=\"toclevel-1 tocsection-4\"><a href=\"#Tailoring\"><span class=\"tocnumber\">4</span> <span class=\"toctext\">Tailoring</span></a></li>\n<li class=\"toclevel-1 tocsection-5\"><a href=\"#Quests\"><span class=\"tocnumber\">5</span> <span class=\"toctext\">Quests</span></a></li>\n<li class=\"toclevel-1 tocsection-6\"><a href=\"#History\"><span class=\"tocnumber\">6</span> <span class=\"toctext\">History</span></a></li>\n</ul>\n</div>\n\n<h2><span class=\"mw-headline\" id=\"Aged_Values\">Aged Values</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/mediawiki/index.php?title=Beer&amp;action=edit&amp;section=1\" title=\"Edit section: Aged Values\">edit</a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>Beer can be placed inside a <a href=\"/Cask\" title=\"Cask\">Cask</a> to age from normal quality to silver, gold, and eventually iridium quality. Iridium quality doubles the base sell price of Beer.  \n</p><p>Normal, silver, and gold quality Beer can be prematurely removed from a cask at any time by striking the cask with an <a href=\"/Axes\" title=\"Axes\">Axe</a>, <a href=\"/Hoes\" title=\"Hoes\">Hoe</a>, or <a href=\"/Pickaxes\" title=\"Pickaxes\">Pickaxe</a>.\n</p>\n<table class=\"wikitable roundedborder\">\n<tbody><tr>\n<th>Normal Quality\n</th>\n<th>Silver Quality<br />(x 1.25)\n</th>\n<th>Gold Quality<br />(x 1.5)\n</th>\n<th>Iridium Quality<br />(x 2)\n</th></tr>\n<tr>\n<td><table class=\"no-wrap\" style=\"text-align: left; margin: 0; padding: 0; border-spacing: 0; border: 0;\">\n<tbody><tr>\n\t<td><link rel=\"mw-deduplicated-inline-style\" href=\"mw-data:TemplateStyles:r146727\"/><div class=\"parent\" style=\"width: 24px; height: auto; margin: 0 auto;\"><div class=\"backimage\"><img alt=\"Beer.png\" src=\"/mediawiki/images/thumb/b/b3/Beer.png/24px-Beer.png\" decoding=\"async\" width=\"24\" height=\"24\" srcset=\"/mediawiki/images/thumb/b/b3/Beer.png/36px-Beer.png 1.5x, /mediawiki/images/b/b3/Beer.png 2x\" /></div><div class=\"foreimage\"></div></div></td>\n\t<td>200g\n\t</td>\n</tr></tbody></table>\n</td>\n<td><table class=\"no-wrap\" style=\"text-align: left; margin: 0; padding: 0; border-spacing: 0; border: 0;\">\n<tbody><tr>\n\t<td><link rel=\"mw-deduplicated-inline-style\" href=\"mw-data:TemplateStyles:r146727\"/><div class=\"parent\" style=\"width: 24px; height: auto; margin: 0 auto;\"><div class=\"backimage\"><img alt=\"Beer.png\" src=\"/mediawiki/images/thumb/b/b3/Beer.png/24px-Beer.png\" decoding=\"async\" width=\"24\" height=\"24\" srcset=\"/mediawiki/images/thumb/b/b3/Beer.png/36px-Beer.png 1.5x, /mediawiki/images/b/b3/Beer.png 2x\" /></div><div class=\"foreimage\"><img alt=\"Silver Quality Icon.png\" src=\"/mediawiki/images/thumb/8/8a/Silver_Quality_Icon.png/24px-Silver_Quality_Icon.png\" decoding=\"async\" width=\"24\" height=\"24\" srcset=\"/mediawiki/images/thumb/8/8a/Silver_Quality_Icon.png/36px-Silver_Quality_Icon.png 1.5x, /mediawiki/images/8/8a/Silver_Quality_Icon.png 2x\" /></div></div></td>\n\t<td>250g\n\t</td>\n</tr></tbody></table> <i>Aged: 7 Days</i>\n</td>\n<td><table class=\"no-wrap\" style=\"text-align: left; margin: 0; padding: 0; border-spacing: 0; border: 0;\">\n<tbody><tr>\n\t<td><link rel=\"mw-deduplicated-inline-style\" href=\"mw-data:TemplateStyles:r146727\"/><div class=\"parent\" style=\"width: 24px; height: auto; margin: 0 auto;\"><div class=\"backimage\"><img alt=\"Beer.png\" src=\"/mediawiki/images/thumb/b/b3/Beer.png/24px-Beer.png\" decodin